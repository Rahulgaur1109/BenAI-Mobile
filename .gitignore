# -----------------------------
# Monorepo-wide ignore rules
# -----------------------------

# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
build/
coverage/
**/dist/
**/build/

# Env / secrets
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Expo / React Native generated
frontend/.expo/
frontend/android/
frontend/ios/
frontend/web-build/
frontend/expo-env.d.ts

# Native signing / cert files
*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS / Editor
.DS_Store
.idea/
.vscode/
